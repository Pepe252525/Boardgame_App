<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvRatingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rating_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvLatestEventLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/latest_event_label"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/layoutCurrentEvent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#E8F0FE"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvCurrentEventDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvCurrentEventHost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_text"
                android:textSize="16sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvCurrentEventLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_text"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <RatingBar
                android:id="@+id/ratingBarCurrent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="1"
                android:rating="0"
                android:max="5"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvCurrentRatingValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_rating_zero"
                android:layout_marginTop="10dp"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnSaveRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save_rating"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPreviousEventsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/last_four_events"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/layoutPastEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>