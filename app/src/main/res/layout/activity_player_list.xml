<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvPlayerListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/player_list_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etPlayerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/player_name_hint"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etPlayerLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/player_location_hint"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnAddPlayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_player_button"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tvPlayersLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/current_players_label"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/layoutPlayers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>